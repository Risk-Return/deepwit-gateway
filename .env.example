# ============================================================
# New API — Environment Configuration
# Copy this file to .env and customize for your environment
# ============================================================

# -------------------- Server --------------------
PORT=3000
# FRONTEND_BASE_URL=https://your-domain.com

# -------------------- Database --------------------
# PostgreSQL (recommended)
# DSN format: postgresql://user:password@host:5432/dbname
# NOTE: If password contains @ or :, URL-encode them (%40 for @, %3A for :)
SQL_DSN=postgresql://user:password@localhost:5432/new-api

# MySQL (alternative)
# SQL_DSN=user:password@tcp(localhost:3306)/new-api?parseTime=true

# SQLite (default if no SQL_DSN set, data stored in /data directory)
# SQLITE_PATH=/data/new-api.db

# Log database (optional, defaults to SQL_DSN if not set)
# LOG_SQL_DSN=postgresql://user:password@localhost:5432/new-api-logs

# Connection pool settings
# SQL_MAX_IDLE_CONNS=100
# SQL_MAX_OPEN_CONNS=1000
# SQL_MAX_LIFETIME=60

# -------------------- Redis (recommended) --------------------
# Format: redis://:password@host:6379
REDIS_CONN_STRING=redis://:your-redis-password@localhost:6379

# -------------------- Security --------------------
# Required for multi-machine deployments and Redis
# Generate with: openssl rand -hex 32
SESSION_SECRET=generate-a-random-64-char-hex-string-here
CRYPTO_SECRET=generate-another-random-64-char-hex-string-here

# -------------------- Performance --------------------
STREAMING_TIMEOUT=300
# RELAY_TIMEOUT=0
# STREAM_SCANNER_MAX_BUFFER_MB=64
# MAX_REQUEST_BODY_MB=32

# Config sync interval (seconds)
SYNC_FREQUENCY=60

# Batch update (recommended for production)
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5

# Memory cache (use Redis instead in production)
# MEMORY_CACHE_ENABLED=true

# -------------------- Features --------------------
ERROR_LOG_ENABLED=true

# Node identity (useful for multi-node deployments and audit logs)
NODE_TYPE=master
NODE_NAME=prod-node-1

# Auto-generate initial root token
# GENERATE_DEFAULT_TOKEN=false

# -------------------- Timezone --------------------
TZ=Asia/Shanghai

# -------------------- OAuth (optional) --------------------
# GitHub
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret

# LinuxDO
# LINUX_DO_CLIENT_ID=your-client-id
# LINUX_DO_CLIENT_SECRET=your-client-secret
# LINUX_DO_MINIMUM_TRUST_LEVEL=0

# Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_BOT_NAME=your-bot-name

# OIDC
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_ISSUER=https://your-oidc-provider.com
# OIDC_END_SESSION_ENABLED=false

# -------------------- Email (optional) --------------------
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_SSL_ENABLED=false
# SMTP_ACCOUNT=your-account
# SMTP_FROM=noreply@example.com
# SMTP_TOKEN=your-smtp-token

# -------------------- Payment (optional) --------------------
# TRUSTED_REDIRECT_DOMAINS=example.com

# -------------------- Analytics (optional) --------------------
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# -------------------- Pyroscope Profiling (optional) --------------------
# PYROSCOPE_URL=http://localhost:4040
# PYROSCOPE_APP_NAME=new-api
